# Cole aqui após rodar: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=COLE_AQUI_A_CHAVE_PUBLICA
VAPID_PRIVATE_KEY=COLE_AQUI_A_CHAVE_PRIVADA
VAPID_EMAIL=secretaria@suaescola.sp.gov.br

# Gerada automaticamente pelo Railway ao adicionar PostgreSQL
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# URL do frontend após deploy (ex: https://secretaria-sem-fila.up.railway.app)
FRONTEND_URL=http://localhost:5173

JWT_SECRET=troque-por-uma-frase-secreta-longa-e-aleatoria
ADMIN_PASSWORD=secretaria123

# ── Z-API (WhatsApp) ──────────────────────────────────────────
# Crie sua conta em: https://z-api.io
# Após criar a instância, copie os valores do painel Z-API
ZAPI_INSTANCE_ID=SUA_INSTANCE_ID
ZAPI_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# Número do WhatsApp da secretaria (com DDD, sem +55)
# Exemplo: 11999998888
WHATSAPP_SECRETARIA=11999998888
